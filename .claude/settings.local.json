{
  "env": {
    "ORCHESTRATION_ENABLED": "true",
    "AUTO_AGENT_SELECTION": "true",
    "RESEARCH_FIRST": "true",
    "TRACK_PROGRESS": "true"
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(awk:*)",
      "Bash(git cat-file:*)",
      "Bash(git ls-tree:*)",
      "Bash(gh pr:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(flutter pub:*)",
      "Bash(flutter analyze:*)",
      "Bash(git commit:*)",
      "Bash(flutter run:*)",
      "Bash(nc localhost 56155)",
      "Bash(flutter test:*)",
      "Bash(tee:*)",
      "Bash(git push)",
      "Bash(flutter clean:*)",
      "Bash(flutter gen-l10n:*)",
      "Bash(nc localhost 55879)",
      "Bash(grep:*)",
      "Bash(powershell -Command:*)",
      "Bash(cat:*)",
      "Bash(flutter_test_full.log)",
      "Bash(timeout 120 flutter test:*)",
      "Bash(git tag:*)",
      "Bash(timeout 60 flutter test:*)",
      "Bash(flutter build:*)",
      "Bash(findstr:*)",
      "Bash(Select-String -Pattern \"(error|Error|ERROR|FAILED)\")",
      "Bash(Select-Object -First 10)",
      "Bash(python -m json.tool:*)",
      "Bash(/dev/null)",
      "Bash(cd /c/Users/Thibaut/Desktop/PriorisProject)",
      "Bash(python3 -)",
      "Bash(rm -f tool_add_i18n_keys.py)",
      "Bash(puro flutter *)",
      "Bash(python3 _bmad/scripts/resolve_customization.py --skill .claude/skills/bmad-sprint-status --key workflow)",
      "Bash(python3 \"C:/Users/Thibaut/Desktop/PriorisProject/_bmad/scripts/resolve_customization.py\" --skill \"C:/Users/Thibaut/Desktop/PriorisProject/.claude/skills/bmad-sprint-status\" --key workflow)",
      "Bash(python3 \"C:/Users/Thibaut/Desktop/PriorisProject/_bmad/scripts/resolve_customization.py\" --skill \"C:/Users/Thibaut/Desktop/PriorisProject/.claude/skills/bmad-code-review\" --key workflow)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"New-Item -ItemType Directory -Force -Path docs\\references, docs\\ADR, tests | Out-Null; Write-Host '✅ Project structure initialized'\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '💡 Consider running tests after code changes'"
          }
        ]
      }
    ]
  }
}
